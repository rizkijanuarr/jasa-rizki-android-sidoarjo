  <!-- ============================================
       MOBILE MENU SCRIPT
       ============================================ -->
  <script>
    const menuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const bar1 = document.getElementById("bar1");
    const bar2 = document.getElementById("bar2");
    const bar3 = document.getElementById("bar3");

    let isOpen = false;

    menuBtn?.addEventListener("click", () => {
      isOpen = !isOpen;
      mobileMenu?.classList.toggle("hidden");

      if (isOpen) {
        bar1!.style.transform = "rotate(45deg) translate(4px, 4px)";
        bar2!.style.opacity = "0";
        bar3!.style.transform = "rotate(-45deg) translate(2px, -2px)";
        bar3!.style.width = "24px";
      } else {
        bar1!.style.transform = "none";
        bar2!.style.opacity = "1";
        bar3!.style.transform = "none";
        bar3!.style.width = "16px";
      }
    });

    // Close menu on link click
    mobileMenu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.classList.add("hidden");
        isOpen = false;
        bar1!.style.transform = "none";
        bar2!.style.opacity = "1";
        bar3!.style.transform = "none";
        bar3!.style.width = "16px";
      });
    });
  </script>

  <!-- ============================================
       ORDER FORM SCRIPT
       ============================================ -->
  <script is:inline>
    // State
    let currentStep = 1;
    let appType = "offline"; // "offline" | "online"

    // Pricing constants
    const RATE_OFFLINE_PER_SCREEN = 500000;
    const RATE_ONLINE_FIRST_SCREEN = 1000000;
    const RATE_ONLINE_ADDITIONAL_SCREEN = 500000;

    // Agreement checkbox logic
    const agreeCheckbox = document.getElementById("agree-terms");
    const btnNext = document.getElementById("btn-next-step");
    if (agreeCheckbox && btnNext) {
      agreeCheckbox.addEventListener("change", function () {
        btnNext.disabled = !this.checked;
      });
    }

    // Step navigation
    function goToStep(step) {
      // Block step 2 if agreement not checked
      if (step === 2 && agreeCheckbox && !agreeCheckbox.checked) {
        agreeCheckbox.parentElement.style.borderColor = "#FF3000";
        agreeCheckbox.focus();
        return;
      }

      currentStep = step;
      const step1 = document.getElementById("step-1");
      const step2 = document.getElementById("step-2");
      const ind1 = document.getElementById("step-ind-1");
      const ind2 = document.getElementById("step-ind-2");

      if (step === 1) {
        step1.classList.remove("hidden");
        step2.classList.add("hidden");
        ind1.classList.add("bg-black", "text-white");
        ind1.classList.remove("bg-white", "text-black");
        ind2.classList.add("bg-white", "text-black");
        ind2.classList.remove("bg-black", "text-white");
      } else {
        step1.classList.add("hidden");
        step2.classList.remove("hidden");
        ind2.classList.add("bg-black", "text-white");
        ind2.classList.remove("bg-white", "text-black");
        ind1.classList.add("bg-white", "text-black");
        ind1.classList.remove("bg-black", "text-white");
        updatePrice();
      }
    }

    // App type toggle
    function setAppType(type) {
      appType = type;
      const btnOffline = document.getElementById("type-offline");
      const btnOnline = document.getElementById("type-online");
      const desc = document.getElementById("type-desc");
      const badge = document.getElementById("app-type-badge");

      if (type === "offline") {
        btnOffline.classList.add("bg-black", "text-white");
        btnOffline.classList.remove("bg-white", "text-black");
        btnOnline.classList.add("bg-white", "text-black");
        btnOnline.classList.remove("bg-black", "text-white");
        desc.textContent = "Aplikasi berjalan tanpa koneksi internet. Cocok untuk tools & utilitas lokal.";
        badge.textContent = "Offline";
      } else {
        btnOnline.classList.add("bg-black", "text-white");
        btnOnline.classList.remove("bg-white", "text-black");
        btnOffline.classList.add("bg-white", "text-black");
        btnOffline.classList.remove("bg-black", "text-white");
        desc.textContent = "Aplikasi terhubung ke internet via RestfulAPI. Cocok untuk sistem yang butuh sinkronisasi data.";
        badge.textContent = "Online + API";
      }

      updatePrice();
    }

    // Screen count adjustment
    function adjustScreen(delta) {
      const input = document.getElementById("screen-count");
      let val = parseInt(input.value) || 1;
      val = Math.max(1, Math.min(100, val + delta));
      input.value = val;
      updatePrice();
    }

    // Format currency
    function formatRupiah(num) {
      return "Rp " + num.toLocaleString("id-ID");
    }

    // Update price display
    function updatePrice() {
      const screens = Math.max(1, parseInt(document.getElementById("screen-count").value) || 1);
      let firstScreenPrice, additionalTotal, total;

      if (appType === "offline") {
        firstScreenPrice = RATE_OFFLINE_PER_SCREEN;
        const additionalScreens = Math.max(0, screens - 1);
        additionalTotal = additionalScreens * RATE_OFFLINE_PER_SCREEN;
        total = screens * RATE_OFFLINE_PER_SCREEN;

        document.getElementById("price-base").textContent = formatRupiah(firstScreenPrice);
        document.getElementById("price-row-base").querySelector("span").textContent = "Screen pertama (Offline)";
        document.getElementById("price-additional-label").textContent = additionalScreens + " screen tambahan × " + formatRupiah(RATE_OFFLINE_PER_SCREEN);
      } else {
        firstScreenPrice = RATE_ONLINE_FIRST_SCREEN;
        const additionalScreens = Math.max(0, screens - 1);
        additionalTotal = additionalScreens * RATE_ONLINE_ADDITIONAL_SCREEN;
        total = firstScreenPrice + additionalTotal;

        document.getElementById("price-base").textContent = formatRupiah(firstScreenPrice);
        document.getElementById("price-row-base").querySelector("span").textContent = "Screen pertama (Online + API)";
        document.getElementById("price-additional-label").textContent = additionalScreens + " screen tambahan × " + formatRupiah(RATE_ONLINE_ADDITIONAL_SCREEN);
      }

      document.getElementById("price-additional").textContent = formatRupiah(additionalTotal);
      document.getElementById("price-total").textContent = formatRupiah(total);
    }

    // Submit order via WhatsApp
    function submitOrder() {
      const clientName = document.getElementById("client-name").value.trim();
      const clientCompany = document.getElementById("client-company").value.trim();
      const clientPhone = document.getElementById("client-phone").value.trim();
      const appName = document.getElementById("app-name").value.trim();
      const appTarget = document.getElementById("app-target").value.trim();
      const appPurpose = document.getElementById("app-purpose").value.trim();
      const appFeatures = document.getElementById("app-features").value.trim();
      const screens = parseInt(document.getElementById("screen-count").value) || 1;
      const totalText = document.getElementById("price-total").textContent;

      if (!appName) {
        document.getElementById("app-name").focus();
        document.getElementById("app-name").style.borderColor = "#FF3000";
        return;
      }

      const jenis = appType === "online" ? "Online" : "Offline";

      let message = `Halo Rizki Android! 👋\n\n`;
      message += `Saya ingin order pembuatan aplikasi Android:\n\n`;
      message += `👤 *PIHAK PERTAMA (CLIENT)*\n`;
      if (clientName) message += `Nama: ${clientName}\n`;
      if (clientCompany) message += `Perusahaan: ${clientCompany}\n`;
      if (clientPhone) message += `WhatsApp: ${clientPhone}\n`;
      message += `\n📱 *DETAIL APLIKASI*\n`;
      message += `Nama: ${appName}\n`;
      if (appTarget) message += `Target: ${appTarget}\n`;
      if (appPurpose) message += `Tujuan: ${appPurpose}\n`;
      message += `\n⚙️ *SPESIFIKASI*\n`;
      message += `Jenis: ${jenis}\n`;
      message += `Jumlah Screen: ${screens}\n`;
      if (appFeatures) message += `Fitur: ${appFeatures}\n`;
      message += `\n💰 *ESTIMASI BIAYA*\n`;
      message += `${totalText}\n`;
      message += `\n✅ Draft Perjanjian Kerja Sama telah disetujui.\n`;
      message += `\nMohon informasi lebih lanjut. Terima kasih!`;

      const encoded = encodeURIComponent(message);
      window.open(`https://wa.me/6285749463854?text=${encoded}`, "_blank");
    }

    // Make functions available globally
    window.goToStep = goToStep;
    window.setAppType = setAppType;
    window.adjustScreen = adjustScreen;
    window.submitOrder = submitOrder;
  </script>

  <!-- Visitor Counter -->
  <script is:inline>
    (function() {
      const NAMESPACE = "rizkiandroid-sidoarjo";
      const KEY = "page-visits";
      const API = `https://api.counterapi.dev/v1/${NAMESPACE}/${KEY}/up`;
      const el = document.getElementById("visitor-count");

      fetch(API)
        .then(res => res.json())
        .then(data => {
          if (el && data.count) {
            el.textContent = data.count.toLocaleString("id-ID");
          }
        })
        .catch(() => {
          if (el) el.textContent = "—";
        });
    })();
  </script>
