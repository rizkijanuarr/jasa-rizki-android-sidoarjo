---
import Layout from "../layouts/Layout.astro";

const services = [
  {
    num: "A",
    title: "Aplikasi Custom",
    desc: "Pembuatan aplikasi Android sesuai kebutuhan bisnis Anda. Dari konsep hingga rilis di Play Store.",
  },
  {
    num: "B",
    title: "UI/UX Design",
    desc: "Desain antarmuka yang intuitif dan menarik, mengutamakan pengalaman pengguna terbaik.",
  },
  {
    num: "C",
    title: "Maintenance & Support",
    desc: "Dukungan teknis berkelanjutan, update fitur, dan perbaikan bug pasca rilis.",
  },
  {
    num: "D",
    title: "Konsultasi IT",
    desc: "Konsultasi gratis untuk menentukan solusi teknologi terbaik bagi bisnis Anda.",
  },
];

const processes = [
  { step: "01", title: "Diskusi & Analisis", desc: "Memahami kebutuhan bisnis dan target pengguna Anda secara mendalam." },
  { step: "02", title: "Perencanaan & Wireframe", desc: "Merancang alur aplikasi dan prototype awal untuk validasi konsep." },
  { step: "03", title: "Desain & Development", desc: "Implementasi desain UI/UX dan pengembangan kode berkualitas tinggi." },
  { step: "04", title: "Testing & QA", desc: "Pengujian menyeluruh di berbagai perangkat Android untuk memastikan kualitas." },
  { step: "05", title: "Rilis & Deployment", desc: "Publikasi ke Google Play Store dan konfigurasi server production." },
  { step: "06", title: "After-Sales Support", desc: "Maintenance rutin, monitoring performa, dan iterasi berdasarkan feedback." },
];

const advantages = [
  { title: "Berpengalaman", desc: "Tim developer berpengalaman dalam berbagai proyek Android skala kecil hingga enterprise." },
  { title: "Harga Terjangkau", desc: "Biaya kompetitif tanpa mengorbankan kualitas. Transparan tanpa biaya tersembunyi." },
  { title: "Tepat Waktu", desc: "Komitmen deadline yang ketat dengan project management profesional." },
  { title: "Teknologi Terkini", desc: "Menggunakan Kotlin, Jetpack Compose, dan arsitektur modern Android." },
  { title: "Support 24/7", desc: "Tim support responsif siap membantu kapanpun Anda membutuhkan." },
  { title: "Lokal Sidoarjo", desc: "Berbasis di Sidoarjo — meeting tatap muka untuk komunikasi yang lebih efektif." },
];

const portfolios = [
  { title: "Aplikasi Kasir POS", category: "Retail & UMKM", year: "2025" },
  { title: "Sistem Manajemen Gudang", category: "Logistik", year: "2025" },
  { title: "Aplikasi Booking Lapangan", category: "Olahraga & Leisure", year: "2024" },
  { title: "Platform E-Learning", category: "Pendidikan", year: "2024" },
];

const testimonials = [
  { name: "Budi Santoso", role: "Owner, Toko Maju Jaya", quote: "Aplikasi kasir dari Rizki Android sangat membantu operasional toko kami. Transaksi jadi lebih cepat dan akurat." },
  { name: "Siti Rahayu", role: "Manager, PT Logistik Nusantara", quote: "Sistem gudang yang dibuatkan sangat robust. Stok barang bisa dipantau real-time dari mana saja." },
  { name: "Ahmad Fauzi", role: "Founder, SportSpace", quote: "Dari konsep sampai rilis hanya 2 bulan. Kualitas top dan timnya sangat komunikatif." },
];

const stats = [
  { number: "50+", label: "Proyek Selesai" },
  { number: "40+", label: "Klien Puas" },
  { number: "4+", label: "Tahun Pengalaman" },
  { number: "99%", label: "Tingkat Kepuasan" },
];
---

<Layout title="Rizki Android — Jasa Pembuatan Aplikasi Android Sidoarjo">
  <!-- ============================================
       NAVIGATION
       ============================================ -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white border-b-4 border-black">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12 flex items-center justify-between h-16 md:h-20">
      <!-- Brand -->
      <a href="#" class="flex items-center gap-3 group">
        <img src="/logo.svg" alt="Rizki Android" class="w-8 h-8 md:w-10 md:h-10 object-contain" />
        <span class="font-black text-sm md:text-base uppercase tracking-tight">Rizki Android</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-8">
        <a href="#layanan" class="nav-link text-xs font-bold uppercase tracking-widest" data-text="Layanan"><span>Layanan</span></a>
        <a href="#proses" class="nav-link text-xs font-bold uppercase tracking-widest" data-text="Proses"><span>Proses</span></a>
        <a href="#keunggulan" class="nav-link text-xs font-bold uppercase tracking-widest" data-text="Keunggulan"><span>Keunggulan</span></a>
        <a href="#portofolio" class="nav-link text-xs font-bold uppercase tracking-widest" data-text="Portofolio"><span>Portofolio</span></a>
        <a
          href="#order"
          class="bg-black text-white px-6 py-3 text-xs font-bold uppercase tracking-widest hover:bg-swiss-accent transition-colors duration-200 ease-out"
        >
          Order Sekarang
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5"
        aria-label="Toggle menu"
      >
        <span class="block w-6 h-0.5 bg-black transition-all duration-200" id="bar1"></span>
        <span class="block w-6 h-0.5 bg-black transition-all duration-200" id="bar2"></span>
        <span class="block w-4 h-0.5 bg-black transition-all duration-200 self-start ml-2" id="bar3"></span>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="lg:hidden hidden border-t-2 border-black bg-white">
      <div class="px-6 py-8 flex flex-col gap-6">
        <a href="#layanan" class="text-lg font-bold uppercase tracking-widest border-b border-black/10 pb-4 hover:text-swiss-accent transition-colors duration-200">Layanan</a>
        <a href="#proses" class="text-lg font-bold uppercase tracking-widest border-b border-black/10 pb-4 hover:text-swiss-accent transition-colors duration-200">Proses</a>
        <a href="#keunggulan" class="text-lg font-bold uppercase tracking-widest border-b border-black/10 pb-4 hover:text-swiss-accent transition-colors duration-200">Keunggulan</a>
        <a href="#portofolio" class="text-lg font-bold uppercase tracking-widest border-b border-black/10 pb-4 hover:text-swiss-accent transition-colors duration-200">Portofolio</a>
        <a href="#order" class="bg-black text-white text-center py-4 text-lg font-bold uppercase tracking-widest hover:bg-swiss-accent transition-colors duration-200">
          Order Sekarang
        </a>
      </div>
    </div>
  </nav>

  <!-- ============================================
       HERO SECTION
       ============================================ -->
  <section class="pt-24 md:pt-32 pb-16 md:pb-24 border-b-4 border-black">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-0">
        <!-- Left: Typography -->
        <div class="lg:col-span-7 flex flex-col justify-center">
          <div class="mb-6 md:mb-8 flex flex-wrap items-center justify-center lg:justify-start gap-3">
			<span class="inline-block text-xs font-bold uppercase tracking-widest text-swiss-accent border-2 border-swiss-accent px-4 py-2">
              Kreativitas Tanpa Batas!
            </span>
            <span class="inline-block text-xs font-bold uppercase tracking-widest text-swiss-accent border-2 border-swiss-accent px-4 py-2">
              Jasa Android Sidoarjo
            </span>
            <span class="inline-block text-xs font-bold uppercase tracking-widest text-white bg-swiss-accent border-2 border-swiss-accent px-4 py-2">
              Mulai dari Rp. 500.000 aja!
            </span>
          </div>

          <h1 class="font-black uppercase leading-[0.85] tracking-tighter mb-8 md:mb-12 text-6xl md:text-8xl lg:text-9xl xl:text-[10rem]">
            Wujudkan<br />
            <span class="text-swiss-accent">Aplikasi</span><br />
            Impian<br />
            Anda
          </h1>

          <p class="text-base md:text-lg font-medium text-black/70 max-w-md mb-10 md:mb-14 leading-relaxed">
            Kami adalah tim developer profesional di Sidoarjo yang mengubah ide bisnis Anda menjadi aplikasi Android berkualitas tinggi.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#order"
              class="bg-black text-white px-8 py-5 text-sm font-bold uppercase tracking-widest hover:bg-swiss-accent transition-colors duration-200 ease-out text-center"
            >
              Mulai Proyek →
            </a>
            <a
              href="#portofolio"
              class="border-2 border-black px-8 py-5 text-sm font-bold uppercase tracking-widest hover:bg-black hover:text-white transition-colors duration-200 ease-out text-center"
            >
              Lihat Portofolio
            </a>
          </div>
        </div>

        <!-- Right: Geometric Composition -->
        <div class="lg:col-span-5 flex items-center justify-center lg:justify-end">
          <div class="relative w-full max-w-[400px] aspect-square">
            <!-- Background grid pattern -->
            <div class="absolute inset-0 bg-swiss-muted swiss-grid-pattern"></div>

            <!-- Large red circle -->
            <div class="absolute top-8 right-8 w-48 h-48 md:w-56 md:h-56 rounded-full bg-swiss-accent opacity-90"></div>

            <!-- Black rectangle -->
            <div class="absolute bottom-12 left-0 w-40 h-56 md:w-48 md:h-64 bg-black"></div>

            <!-- Small outlined circle -->
            <div class="absolute top-4 left-12 w-20 h-20 rounded-full border-4 border-black"></div>

            <!-- Thick horizontal line -->
            <div class="absolute bottom-8 right-0 w-3/4 h-1 bg-swiss-accent"></div>

            <!-- Small black square -->
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-16 h-16 bg-black border-4 border-white"></div>

            <!-- Vertical line -->
            <div class="absolute top-0 right-24 w-1 h-3/5 bg-black"></div>

            <!-- Dot matrix overlay -->
            <div class="absolute inset-0 swiss-dots opacity-50"></div>

            <!-- Android text label -->
            <div class="absolute bottom-20 right-12 bg-white border-2 border-black px-3 py-1.5">
              <span class="text-[10px] font-black uppercase tracking-widest">Android Dev</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Stats Row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-0 border-t-4 border-black mt-16 md:mt-24">
        {stats.map((stat, i) => (
          <div class={`py-8 md:py-12 px-4 md:px-8 group cursor-default hover:bg-black transition-colors duration-200 ${i < 3 ? "border-r-2 border-black" : ""} ${i < 2 ? "border-b-2 md:border-b-0 border-black" : ""}`}>
            <div class="font-black text-4xl md:text-5xl lg:text-6xl tracking-tighter group-hover:text-swiss-accent group-hover:scale-105 transition-all duration-200 origin-left">
              {stat.number}
            </div>
            <div class="text-xs font-bold uppercase tracking-widest mt-2 text-black/60 group-hover:text-white/80 transition-colors duration-200">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       01. LAYANAN (Services)
       ============================================ -->
  <section id="layanan" class="py-16 md:py-24 border-b-4 border-black">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <!-- Section Header -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16 md:mb-20">
        <div class="lg:col-span-5">
          <span class="text-xs font-bold uppercase tracking-widest text-swiss-accent">01. Layanan</span>
          <h2 class="font-black uppercase text-5xl md:text-7xl lg:text-8xl tracking-tighter leading-[0.9] mt-4">
            Apa Yang<br />Kami<br />Tawarkan
          </h2>
        </div>
        <div class="lg:col-span-5 lg:col-start-8 flex items-end">
          <p class="text-base md:text-lg font-medium text-black/60 leading-relaxed">
            Solusi lengkap pengembangan aplikasi Android untuk bisnis Anda — dari perencanaan, desain, development, hingga maintenance.
          </p>
        </div>
      </div>

      <!-- Services Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
        {services.map((service, i) => (
          <div class={`group border-2 border-black p-8 md:p-12 hover:bg-swiss-accent transition-colors duration-200 cursor-default ${i % 2 === 0 ? "md:border-r-0" : ""} ${i < 2 ? "border-b-0 md:border-b-2" : ""} ${i === 0 ? "border-b-0" : ""} ${i === 2 ? "md:border-t-0" : ""}`} style={i < 2 ? "" : ""}>
            <div class="flex items-start justify-between mb-6">
              <span class="text-6xl md:text-7xl font-black tracking-tighter text-black/10 group-hover:text-white/30 transition-colors duration-200">
                {service.num}
              </span>
              <div class="w-10 h-10 border-2 border-black group-hover:border-white flex items-center justify-center transition-colors duration-200">
                <span class="text-lg font-bold group-hover:text-white transition-colors duration-200 group-hover:rotate-45 inline-block origin-center" style="transition: transform 200ms ease-out, color 200ms ease-out;">→</span>
              </div>
            </div>
            <h3 class="font-black text-xl md:text-2xl uppercase tracking-tight mb-4 group-hover:text-white transition-colors duration-200">
              {service.title}
            </h3>
            <p class="text-sm md:text-base text-black/60 group-hover:text-white/80 transition-colors duration-200 leading-relaxed">
              {service.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       02. PROSES (Process)
       ============================================ -->
  <section id="proses" class="py-16 md:py-24 bg-swiss-muted swiss-dots border-b-4 border-black">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16 md:mb-20">
        <div class="lg:col-span-7">
          <span class="text-xs font-bold uppercase tracking-widest text-swiss-accent">02. Proses</span>
          <h2 class="font-black uppercase text-5xl md:text-7xl lg:text-8xl tracking-tighter leading-[0.9] mt-4">
            Cara Kami<br />Bekerja
          </h2>
        </div>
        <div class="lg:col-span-4 lg:col-start-9 flex items-end">
          <p class="text-base md:text-lg font-medium text-black/60 leading-relaxed">
            Metodologi terstruktur yang memastikan setiap proyek berjalan efisien dari awal hingga akhir.
          </p>
        </div>
      </div>

      <!-- Process Steps -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-0">
        {processes.map((process, i) => (
          <div class={`bg-white border-2 border-black p-8 md:p-10 group hover:bg-black transition-colors duration-200 cursor-default`}>
            <div class="flex items-baseline gap-4 mb-6">
              <span class="text-4xl md:text-5xl font-black tracking-tighter text-swiss-accent">
                {process.step}
              </span>
              <div class="flex-1 h-0.5 bg-black/10 group-hover:bg-white/20 transition-colors duration-200"></div>
            </div>
            <h3 class="font-black text-lg md:text-xl uppercase tracking-tight mb-3 group-hover:text-white transition-colors duration-200">
              {process.title}
            </h3>
            <p class="text-sm text-black/60 group-hover:text-white/70 transition-colors duration-200 leading-relaxed">
              {process.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       03. KEUNGGULAN (Advantages)
       ============================================ -->
  <section id="keunggulan" class="py-16 md:py-24 border-b-4 border-black">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">
        <!-- Left: Sticky Header -->
        <div class="lg:col-span-5">
          <div class="lg:sticky lg:top-28">
            <span class="text-xs font-bold uppercase tracking-widest text-swiss-accent">03. Keunggulan</span>
            <h2 class="font-black uppercase text-5xl md:text-7xl lg:text-8xl tracking-tighter leading-[0.9] mt-4 mb-6">
              Mengapa<br />Pilih<br />Kami?
            </h2>
            <p class="text-base md:text-lg font-medium text-black/60 leading-relaxed max-w-sm mb-8">
              Kami menggabungkan keahlian teknis, pemahaman bisnis lokal, dan komitmen terhadap kualitas.
            </p>

            <!-- Geometric element -->
            <div class="hidden lg:block relative w-full max-w-[280px] h-48 bg-swiss-muted swiss-diagonal">
              <div class="absolute top-6 left-6 w-24 h-24 bg-swiss-accent"></div>
              <div class="absolute bottom-6 right-6 w-16 h-16 border-4 border-black rounded-full"></div>
              <div class="absolute top-0 right-0 w-1 h-full bg-black"></div>
            </div>
          </div>
        </div>

        <!-- Right: Advantages List -->
        <div class="lg:col-span-7">
          <div class="flex flex-col">
            {advantages.map((adv, i) => (
              <div class={`group py-8 md:py-10 ${i > 0 ? "border-t-2 border-black" : ""} cursor-default hover:pl-4 transition-all duration-200`}>
                <div class="flex items-start gap-6">
                  <span class="text-3xl md:text-4xl font-black tracking-tighter text-black/10 group-hover:text-swiss-accent transition-colors duration-200 shrink-0">
                    0{i + 1}
                  </span>
                  <div>
                    <h3 class="font-black text-xl md:text-2xl uppercase tracking-tight mb-2 group-hover:text-swiss-accent transition-colors duration-200">
                      {adv.title}
                    </h3>
                    <p class="text-sm md:text-base text-black/60 leading-relaxed">
                      {adv.desc}
                    </p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       04. PORTOFOLIO (Portfolio)
       ============================================ -->
  <section id="portofolio" class="py-16 md:py-24 bg-black text-white border-b-4 border-black">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16 md:mb-20">
        <div class="lg:col-span-8">
          <span class="text-xs font-bold uppercase tracking-widest text-swiss-accent">04. Portofolio</span>
          <h2 class="font-black uppercase text-5xl md:text-7xl lg:text-8xl tracking-tighter leading-[0.9] mt-4">
            Proyek<br />Terbaru Kami
          </h2>
        </div>
      </div>

      <!-- Portfolio Items -->
      <div class="flex flex-col">
        {portfolios.map((item, i) => (
          <div class={`group py-8 md:py-12 ${i > 0 ? "border-t border-white/20" : "border-t border-white/20"} cursor-pointer hover:pl-6 transition-all duration-200`}>
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 items-center">
              <div class="md:col-span-1">
                <span class="text-xs font-bold tracking-widest text-white/30 group-hover:text-swiss-accent transition-colors duration-200">
                  {String(i + 1).padStart(2, "0")}
                </span>
              </div>
              <div class="md:col-span-5">
                <h3 class="font-black text-2xl md:text-3xl lg:text-4xl uppercase tracking-tight group-hover:text-swiss-accent transition-colors duration-200">
                  {item.title}
                </h3>
              </div>
              <div class="md:col-span-3">
                <span class="text-xs font-bold uppercase tracking-widest text-white/50">
                  {item.category}
                </span>
              </div>
              <div class="md:col-span-2">
                <span class="text-xs font-bold uppercase tracking-widest text-white/30">
                  {item.year}
                </span>
              </div>
              <div class="md:col-span-1 flex justify-end">
                <div class="w-10 h-10 border-2 border-white/30 group-hover:border-swiss-accent group-hover:bg-swiss-accent flex items-center justify-center transition-all duration-200">
                  <span class="text-white text-lg group-hover:-rotate-45 inline-block transition-transform duration-200">→</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 md:mt-16 pt-8 border-t border-white/20">
        <a
          href="#kontak"
          class="inline-block border-2 border-white px-8 py-5 text-sm font-bold uppercase tracking-widest hover:bg-swiss-accent hover:border-swiss-accent transition-colors duration-200 ease-out"
        >
          Diskusikan Proyek Anda →
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       05. TESTIMONI (Testimonials)
       ============================================ -->
  <section id="testimoni" class="py-16 md:py-24 bg-swiss-muted swiss-grid-pattern border-b-4 border-black">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="mb-16 md:mb-20">
        <span class="text-xs font-bold uppercase tracking-widest text-swiss-accent">05. Testimoni</span>
        <h2 class="font-black uppercase text-5xl md:text-7xl lg:text-8xl tracking-tighter leading-[0.9] mt-4">
          Kata Mereka
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-0">
        {testimonials.map((t, i) => (
          <div class={`bg-white border-2 border-black p-8 md:p-10 group hover:-translate-y-px hover:border-swiss-accent transition-all duration-200 cursor-default`}>
            <!-- Quote mark -->
            <div class="text-6xl font-black leading-none text-swiss-accent mb-4 select-none">"</div>
            <p class="text-sm md:text-base text-black/70 group-hover:text-black leading-relaxed mb-8 transition-colors duration-200">
              {t.quote}
            </p>
            <div class="border-t-2 border-black pt-6">
              <div class="font-black text-sm uppercase tracking-tight">{t.name}</div>
              <div class="text-xs text-black/50 uppercase tracking-widest mt-1">{t.role}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       06. ORDER FORM
       ============================================ -->
  <section id="order" class="py-16 md:py-24 bg-swiss-muted swiss-grid-pattern border-b-4 border-black">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">
        <!-- Left: Section Header -->
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-28">
            <span class="text-xs font-bold uppercase tracking-widest text-swiss-accent">06. Order</span>
            <h2 class="font-black uppercase text-4xl md:text-5xl lg:text-6xl tracking-tighter leading-[0.9] mt-4 mb-6">
              Pesan<br />Sekarang
            </h2>
            <p class="text-base font-medium text-black/60 leading-relaxed mb-8">
              Isi form di bawah untuk mendapatkan estimasi biaya secara langsung. Kirim order via WhatsApp.
            </p>

            <!-- Pricing Info -->
            <div class="hidden lg:block bg-white border-2 border-black p-6">
